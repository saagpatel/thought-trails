{
	"productName": "thought-trails",
	"version": "0.1.0",
	"identifier": "com.thoughttrails.app",
	"build": {
		"beforeDevCommand": "npm run dev",
		"beforeBuildCommand": "npm run build",
		"devUrl": "http://localhost:5173",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"title": "thought-trails",
				"width": 1100,
				"height": 700,
				"minWidth": 900,
				"minHeight": 600,
				"resizable": true,
				"decorations": true
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
